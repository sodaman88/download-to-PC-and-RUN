<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Glitch Visual</title>

<style>
body{
  margin:0;
  background:black;
  overflow:hidden;
}

canvas{
  position:absolute;
  top:0;
  left:0;
}
</style>
</head>

<body>

<canvas id="c"></canvas>

<script>
const canvas = document.getElementById("c");
const ctx = canvas.getContext("2d");

function resize(){
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;
}
resize();
window.onresize = resize;

function rand(min,max){
  return Math.random()*(max-min)+min;
}

function draw(){

  ctx.fillStyle="rgba(0,0,0,0.25)";
  ctx.fillRect(0,0,canvas.width,canvas.height);

  for(let i=0;i<8000;i++){

    const x = rand(0,canvas.width);
    const y = rand(0,canvas.height);

    const w = rand(200,800);
    const h = rand(50,300);

    ctx.fillStyle = `hsl(${Math.random()*360},100%,50%)`;
    ctx.fillRect(x,y,w,h);

  }

  requestAnimationFrame(draw);
}

draw();

/* glitch sound */

const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

function glitch(){

  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();

  osc.type="sawtooth";
  osc.frequency.value = rand(60,3000);

  gain.gain.value = 0.2;

  osc.connect(gain);
  gain.connect(audioCtx.destination);

  osc.start();
  osc.stop(audioCtx.currentTime+0.05);

}

setInterval(glitch,60);

</script>

</body>
</html>
<!DOCTYPE html>
<html>
<head>
<style>
body {
  margin:0;
  height:100vh;
  cursor:none; /* hide the real cursor */
  background:black;
}

#fakeCursor {
  width:20px;
  height:20px;
  background:red;
  border-radius:50%;
  position:absolute;
  pointer-events:none;
}
</style>
</head>
<body>

<div id="fakeCursor"></div>

<script>
const cursor = document.getElementById("fakeCursor");

// Start in center
let x = window.innerWidth/2;
let y = window.innerHeight/2;

// Move fake cursor randomly every frame
function animate(){
  x += (Math.random()-0.5)*30; // move randomly
  y += (Math.random()-0.5)*30;

  // Keep it on screen
  x = Math.max(0, Math.min(window.innerWidth-20, x));
  y = Math.max(0, Math.min(window.innerHeight-20, y));

  cursor.style.left = x + "px";
  cursor.style.top = y + "px";

  requestAnimationFrame(animate);
}

animate();
</script>

</body>
</html>